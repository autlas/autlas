{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@tauri-apps/api/core": ["./src/shims/tauri-core.ts"],
      "@tauri-apps/api/event": ["./src/shims/tauri-event.ts"],
      "@tauri-apps/api/webviewWindow": ["./src/shims/tauri-webview.ts"],
      "@tauri-apps/api/dpi": ["./src/shims/tauri-dpi.ts"],
      "@tauri-apps/plugin-dialog": ["./src/shims/tauri-dialog.ts"]
    }
  },
  "include": ["src"]
}
